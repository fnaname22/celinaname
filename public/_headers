/*
  Cache-Control: public, max-age=0, must-revalidate

# Static assets - Caching for 1 year
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Videos - Caching for 1 year
/videos/*
  Cache-Control: public, max-age=31536000, immutable

# Images in public folder
/videos/thumbs/*
  Cache-Control: public, max-age=31536000, immutable
